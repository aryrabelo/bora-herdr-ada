#!/usr/bin/env sh
# bora — manage the bora-herdr-ada fork build and upstream sync.
#
# Branch model:
#   master  1:1 mirror of upstream ogulcancelik/herdr:master, only fast-forwarded.
#   main    default branch = master + our features (squash-merged PRs).
#           kept current by rebasing onto master (`scripts/bora sync`).
#
# The built binary is `bora` with its own config namespace (bora/bora-dev), so
# it coexists with a stock herdr from brew/mise without overwriting it.
#
# Usage:
#   scripts/bora sync       fast-forward master to upstream, then rebase main onto it
#   scripts/bora build      cargo build --release, install bin as bora
#   scripts/bora ci-build   trigger the GitHub Actions macOS build on the fork (main)
#   scripts/bora ci-install download the latest macOS CI artifact, install it
#   scripts/bora install <file>  install an arbitrary binary as bora
#   scripts/bora run [args]  run bora on the dedicated "bora" session
#
# ponytail: a thin sh wrapper, not a framework. Build needs a working zig
# toolchain; on macOS 26 the vendored libghostty (zig 0.15.2) does not link
# locally, so use the prebuilt (`just build-libghostty-vt-prebuilt`) or
# `ci-build` + `ci-install` until the toolchain is fixed.

set -eu

REPO_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
BIN_DIR="${HERDR_BORA_BIN_DIR:-$HOME/.local/bin}"
BIN="$BIN_DIR/bora"
SESSION="${HERDR_BORA_SESSION:-bora}"
UPSTREAM_REMOTE="${HERDR_BORA_UPSTREAM:-origin}"
UPSTREAM_BRANCH="${HERDR_BORA_UPSTREAM_BRANCH:-master}"
FORK_REMOTE="${HERDR_BORA_FORK:-fork}"

cmd=${1:-help}
[ $# -gt 0 ] && shift || true

# CI-downloaded macOS binaries are unsigned/quarantined; macOS kills them with
# "killed: 9" until they are ad-hoc signed. Locally-built binaries don't need this.
sign_bin() {
  xattr -cr "$BIN" 2>/dev/null || true
  command -v codesign >/dev/null 2>&1 && codesign --force --sign - "$BIN" 2>/dev/null || true
}

case "$cmd" in
  sync)
    cd "$REPO_DIR"
    git fetch "$UPSTREAM_REMOTE" "$UPSTREAM_BRANCH"
    # master mirrors upstream 1:1 — fast-forward only, never carries fork commits.
    git push "$FORK_REMOTE" "$UPSTREAM_REMOTE/$UPSTREAM_BRANCH:refs/heads/master"
    git fetch "$FORK_REMOTE" master
    # replay main's feature commits on top of the refreshed master.
    git checkout main
    git rebase "$FORK_REMOTE/master"
    echo "bora: master fast-forwarded to $UPSTREAM_REMOTE/$UPSTREAM_BRANCH and main rebased onto it."
    echo "bora: review, then publish with: git push --force-with-lease $FORK_REMOTE main"
    ;;
  build)
    cd "$REPO_DIR"
    cargo build --release --locked
    mkdir -p "$BIN_DIR"
    cp target/release/bora "$BIN"
    chmod +x "$BIN"
    echo "bora: installed $("$BIN" --version 2>/dev/null || echo bora) -> $BIN"
    ;;
  ci-build)
    cd "$REPO_DIR"
    git push "$FORK_REMOTE" main
    gh workflow run build-artifacts-manual.yml --repo "$(gh repo view --json nameWithOwner -q .nameWithOwner)" \
      --ref main -f build_group=macos -f libghostty_optimize=ReleaseFast -f libghostty_simd=false
    echo "bora: dispatched macOS build for branch main. Watch: gh run watch ; then: scripts/bora ci-install"
    ;;
  ci-install)
    cd "$REPO_DIR"
    tmp=$(mktemp -d)
    gh run download --repo "$(gh repo view --json nameWithOwner -q .nameWithOwner)" --dir "$tmp" \
      $( [ $# -gt 0 ] && echo "$1" )
    found=$(find "$tmp" -type f -name 'bora*' ! -name '*.txt' ! -name '*.json' | head -1)
    [ -n "$found" ] || { echo "bora: no bora binary found in artifacts under $tmp" >&2; exit 1; }
    mkdir -p "$BIN_DIR"
    cp "$found" "$BIN"
    chmod +x "$BIN"
    sign_bin
    rm -rf "$tmp"
    echo "bora: installed CI binary -> $BIN"
    ;;
  install)
    [ $# -ge 1 ] || { echo "usage: scripts/bora install <file>" >&2; exit 1; }
    mkdir -p "$BIN_DIR"
    cp "$1" "$BIN"
    chmod +x "$BIN"
    sign_bin
    echo "bora: installed $1 -> $BIN"
    ;;
  run)
    [ -x "$BIN" ] || { echo "bora: $BIN not installed; run scripts/bora build or ci-install" >&2; exit 1; }
    exec "$BIN" --session "$SESSION" "$@"
    ;;
  help|*)
    sed -n '2,24p' "$0"
    ;;
esac
